/** 依合約資料組出佔位符對照表 */
function buildPlaceholders(c) {
  const s = getSettings();
  return {
    tenant_name: c.name || '',
    id_no: c.id_no || '',
    phone: c.phone || '',
    mail_addr: c.mail_addr || '',
    property_addr: String(s['property.addr'] || ''),
    room_bed: (c.room + ' ' + (c.bed || '')).trim(),
    term_start_roc: fmtRoc(c.term_start),
    term_end_roc: fmtRoc(c.term_end),
    rent: Number(c.rent || 0).toLocaleString(),
    fee_mgmt: c.fee_mgmt || '由出租人負擔',
    fee_water: c.fee_water || '由出租人負擔',
    fee_power: c.fee_power || '由出租人負擔',
    lessor_name: String(s['lessor.name'] || ''),
    lessor_taxid: String(s['lessor.taxid'] || ''),
    lessor_addr: String(s['lessor.addr'] || ''),
    lessor_phone: String(s['lessor.phone'] || ''),
    sign_date_roc: fmtRoc(c.signed_at || new Date()),  // 直接餵 Date 物件；String().slice 會產生 'Thu Jul 23' → 被解析成 2001 年（民國90）
  };
}

function fillPlaceholders(text, ph) {
  return String(text).replace(/\{\{(\w+)\}\}/g, function (m, k) {
    return ph[k] !== undefined ? ph[k] : m;
  });
}

/** 給前端與 PDF 共用的「已填好的條文」 */
function renderTerms(c) {
  const ph = buildPlaceholders(c);
  const prices = EQUIP_ITEMS.map(function (k) {
    return { item: k, qty: 1, price: Number(getSettings()['price.' + k] || 0) };
  });
  return {
    version: TERMS_VERSION,
    clauses: TERMS.map(function (t) {
      return { no: t.no, title: t.title, body: fillPlaceholders(t.body, ph) };
    }),
    annex1: { title: '附件一　承租人歸還設備範圍明細表', prices: prices, footer: ANNEX1_FOOTER },
    annex2: { title: '附件二　鼎兆元員工宿舍規約', sections: ANNEX2 },
    placeholders: ph,
  };
}

/** 驗收：條文數量、佔位符有沒有漏填 */
function testTerms() {
  const c = { name: '王小明', id_no: 'A123456789', phone: '0912345678',
              mail_addr: '新竹市測試路1號', room: '三樓1號房', bed: '雙人床位A',
              rent: 2000, deposit_type: '集團內免押', deposit_amt: 0,
              term_start: '2026-08-01', term_end: '2027-01-31' };
  const r = renderTerms(c);
  Logger.log('① 條文數：' + r.clauses.length + ' 條（應為 18）');
  Logger.log('② 附件二段落數：' + r.annex2.sections.length + '（應為 8）');
  const all = r.clauses.map(function (x) { return x.body; }).join('\n');
  const left = all.match(/\{\{\w+\}\}/g);
  Logger.log('③ 未填的佔位符：' + (left ? left.join('、') : '無 ✅'));
  Logger.log('④ 第一條租賃範圍：' + r.clauses[0].body.split('\n')[2].trim());
  Logger.log('⑤ 第三條金額：' + r.clauses[2].body.split('\n')[0]);
  Logger.log('⑥ 賠償單價合計：' + r.annex1.prices.reduce(function (a, b) { return a + b.price; }, 0)
             + '（應為 14900）');
}
